{
  "name": "RemoteRetro",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "backend",
  "workspaceFolder": "/app",
  "overrideCommand": true,
  "forwardPorts": [4000, 8080],
  "postCreateCommand": "bash -l .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "JakeBecker.elixir-ls",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
